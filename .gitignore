# Build artifacts
/seeurchin
/dist
/tmp

# Embedded frontend build output (generated by `npm run build` in web/).
# Keep .gitkeep committed so the Go `embed` directive compiles on a fresh
# checkout; the Docker build regenerates the real assets.
/internal/httpapi/webdist/*
!/internal/httpapi/webdist/.gitkeep

# Local data / config
*.db
*.db-shm
*.db-wal
/config/

# Node
web/node_modules/
web/.svelte-kit/
web/build/

# Env
.env
.env.local

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
